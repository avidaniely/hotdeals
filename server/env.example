# ── Server ───────────────────────────────────────
PORT=5000
CLIENT_URL=http://localhost:3000

# ── MySQL ────────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_mysql_password_here
DB_NAME=hotdeals

# ── JWT ──────────────────────────────────────────
